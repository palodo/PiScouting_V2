# Configuración de PiScouting. Copia este fichero a `.env` (en la raíz del repo) y ajusta valores.
# El backend carga `.env` automáticamente al arrancar. NO subas tu `.env` real a git.

# Secreto para firmar los tokens JWT de login. OBLIGATORIO cambiarlo en producción.
# Genera uno con: python -c "import secrets; print(secrets.token_urlsafe(48))"
PISCOUTING_SECRET=cambia-esto-por-un-secreto-largo-y-aleatorio

# Días de validez de la sesión (token JWT). Opcional, por defecto 30.
PISCOUTING_TOKEN_TTL_DAYS=30
